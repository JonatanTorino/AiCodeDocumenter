public class AxnLicSubscriptionExtension extends common
{
    public static AxnLicSubscriptionExtension findByExtensionId(str _extensionId, boolean _forUpdate = false)
    {
        AxnLicSubscriptionExtension subscriptionExtension;
        subscriptionExtension.selectForUpdate(_forUpdate);
        select firstOnly subscriptionExtension
            where subscriptionExtension.ExtensionId == _extensionId;

        return subscriptionExtension;
    }
}